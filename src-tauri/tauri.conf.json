{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MINION",
  "version": "1.8.0",
  "identifier": "dev.minion.app",
  "build": {
    "beforeDevCommand": { "cwd": "../ui", "script": "pnpm dev" },
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": { "cwd": "../ui", "script": "pnpm build" },
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MINION",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
